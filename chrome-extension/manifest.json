{
  "manifest_version": 3,
  "name": "Markdown to Google Slides",
  "short_name": "MD to Slides",
  "version": "1.0.0",
  "description": "Convert Markdown (Marp format) text to Google Slides. Paste your Markdown and automatically generate presentation slides.",
  "permissions": [
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://slides.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "YOUR_OAUTH2_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/presentations"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Markdown to Google Slides",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
